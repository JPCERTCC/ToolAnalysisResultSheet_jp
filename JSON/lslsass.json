{
    "Summary": {
        "ToolName": "lslsass",
        "Category": "パスワード、ハッシュ入手",
        "Description": "lsassプロセスから、有効なログオンセッションのパスワードハッシュを取得する。",
        "Usage": "取得したパスワードハッシュ値を使用してリモートホストにログオンする。",
