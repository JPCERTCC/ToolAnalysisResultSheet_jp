{
    "Summary": {
        "ToolName": "AzureHound",
        "Category": "情報収集",
        "Description": "BloodHoundで攻撃対象調査をする際にAzure用のデータコレクタとして使用される。オプションで指定するとJSONファイルが1つ生成される。SharpHoundと組み合わせてハイブリット構成の分析ができる。",
        "Usage": "Entra IDの情報を収集し、攻撃対象候補の調査を行う。侵害済みのアカウントからより高位のアカウントへの権限昇格経路を調査する。Entra ID設定に悪用可能な脆弱性が存在するか調査する。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "none",
            "Windows 10 + Windows Server 2012": "none",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Source": {
            "OS": "Windows",
            "DomainMember": true,
            "Privilege": "標準ユーザー",
            "Protocol": [
                "53/udp",
                "80/tcp",
                "443/tcp"
            ],
            "Note": "HTTPSによる443/tcpのため、環境によっては443/udpも発生し得る。"
        }
    },
    "Findings": {
        "Original": {
            "Source": {
                "Prefetch": "実行履歴"
            }
        },
        "Additional": {
            "Source": {
                "監査ポリシー・Sysmon": "BloodHoundにデータ投入するJSONファイルの作成が記録される。Azure関連の通信があったことが記録される",
                "パケットキャプチャ": "次のドメインへのHTTP(S)通信が発生する：wdcp.microsoft.com, cp601.prod.do.dsp.mp.microsoft.com, login.microsoftonline.com, graph.microsoft.com, management.azure.com。また、Microsoft Azure宛の通信が記録される。"
            }
        }
    },
    "SuccessCondition": {
        "Source": [
            "Microsoft Azure、Microsoft Sign-in、Microsoft Graph APIの通信が記録されている",
            "BloodHoundに投入するJSONファイルが作成される（オプションで出力先をファイルにした場合。オプションで指定しない場合は標準出力される）"
        ]
    },
