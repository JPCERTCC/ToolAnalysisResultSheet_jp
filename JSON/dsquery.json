{
    "Summary": {
        "ToolName": "dsquery",
        "Category": "情報収集",
        "Description": "Active Directoryから、ユーザーやグループなどの情報を取得する。",
        "Usage": "Active Directoryからアカウント情報を収集し、攻撃対象として利用可能なユーザーやホストを選択する。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Domain Controller": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "標準ユーザー (ただし、実行するユーザの権限により取得出来ない情報が存在する)",
            "Protocol": [
                "389/tcp"
            ]
        }
    },
    "Findings": {
        "Additional": {
            "Domain Controller": {
                "監査ポリシー・Sysmon": "実行履歴"
            }
        }
    },
    "SuccessCondition": {
        "Domain Controller": [
            "dsqueryコマンドの実行が実行履歴に記録されている"
        ]
    },
    "KeyEvents": {
        "Domain Controller": {
            "EventLogs": [
                {
                    "Channel": "Security",
                    "EventID": 4688,
                    "SubjectUserSid": "[ユーザーSID]",
                    "SubjectUserName": "[ユーザー名]",
                    "SubjectDomainName": "[ドメイン名]",
                    "SubjectLogonId": "[ログオンID]",
                    "NewProcessId": "[新しく実行されたプロセスのプロセスID]",
                    "NewProcessName": "[実行ファイルのパス]",
                    "TokenElevationType": "TokenElevationTypeDefault(1)",
                    "CommandLine": "[実行ファイルのパス] [クエリ]",
                    "ProcessId": "[親プロセスID]"
                },
                {
                    "Channel": "Security",
                    "EventID": 5156,
                    "ProcessId": "[実行プロセスID]",
                    "Application": "[実行ファイルのパス]",
                    "Direction": "送信",
                    "SourceAddress": "[接続元IPアドレス]",
                    "SourcePort": "[送信元ポート番号]",
                    "DestAddress": "[ドメインコントローラーIPアドレス]",
                    "DestPort": "389",
                    "Protocol": "6 (TCP)"
                }
            ]
        }
    },
