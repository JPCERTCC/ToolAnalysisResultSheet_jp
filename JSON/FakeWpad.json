{
    "Summary": {
        "ToolName": "Fake wpad",
        "Category": "通信の不正中継",
        "Description": "wpadサーバーとして動作し、クライアントからの通信内容を取得・変更する。",
        "Usage": "クライアントから外部Webサイトへの通信を不正中継することでレスポンスを改変し、攻撃者のサイトに誘導する不正なURLを埋め込む。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "false"
        }
    },
    "ExecCondition": {
        "Source": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "User",
            "Protocol": [
                "80/tcp",
                "8888/tcp"
            ]
        },
        "Target": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "Admin",
            "Protocol": [
                "80/tcp",
                "8888/tcp"
            ],
            "Note": "Windowsファイアウォールで受信を許可する変更が必要なため、管理者権限が必要"
        }
    },
    "Findings": {
        "Original": {
            "Source": {
                "レジストリ": "最後に取得されたプロキシ設定（レジストリ）が記録される ※通常時からwpadを使用している場合は区別出来ない"
            },
            "Target": {
                "Prefetch": "実行履歴"
            }
        },
        "Additional": {
            "Source": {
                "監査ポリシー・Sysmon": "検体を実行しているホストに対して、80/tcp及び8888/tcpで通信していることが記録される",
                "監査ポリシー": "wpad.datのキャッシュが作成されたことが記録される"
            },
            "Target": {
                "監査ポリシー": "80/tcp及び8888/tcpをリッスンしたことが記録される。wpad.datや、プロキシのログであるproxy.logに対するハンドルの要求が記録される"
            }
        }
    },
    "SuccessCondition": {
        "Source": [
            "本来プロキシやHTTPサーバーで無いはずのホストと、80/tcp及び8888/tcpによる通信を行っている。"
        ],
        "Target": [
            "本来プロキシやHTTPサーバーで無いはずのホストが、80/tcp及び8888/tcpをリッスンしている。wpad.dat・proxy.logが作成されている。"
        ]
    },
