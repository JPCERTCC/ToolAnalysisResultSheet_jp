{
    "Summary": {
        "ToolName": "csvde",
        "Category": "情報収集",
        "Description": "Active Directory上のアカウント情報をCSV形式で出力する。",
        "Usage": "Active Directoryからアカウント情報を収集し、攻撃対象として利用可能なユーザーやホストを選択する。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Source": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "User",
            "Protocol": [
	            "389/tcp"
            ]
        }
    },
    "Findings": {
