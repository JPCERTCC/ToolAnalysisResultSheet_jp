{
    "Summary": {
        "ToolName": "dcdiag",
        "Category": "情報収集",
        "Description": "ドメインコントローラーの状態を分析・調査する。",
        "Usage": "ドメインコントローラーの問題を調査し、それを利用して攻撃手法を検討する。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Domain Controller": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": ["標準ユーザ","管理ユーザ"]
        }
    },
    "Findings": {
        "Original": {
            "Domain Controller": {
                "MFT・USNジャーナル": "\"/f\"オプションを指定した場合、出力されるログファイルの作成が記録される。ターミナル上で実施したのみの場合は区別出来ない"
            }
        },
        "Additional": {
            "Domain Controller": {
                "監査ポリシー・Sysmon": "実行履歴、/\"f\"オプションを指定した場合の出力ファイルの作成"
            }
        }
    },
    "SuccessCondition": {
        "Domain Controller": [
            "dcdiag.exeが実行され、終了状態が0となっている",
            "\"/f\"オプションを指定した場合は、指定したファイルが作成されている"
        ]
    },
