{
    "Summary": {
        "ToolName": "nmap",
        "Category": "情報収集",
        "Description": "ネットワーク調査に使用する。",
        "Usage": "ネットワーク内に存在するホストの列挙や、接続可能なポートの調査に使用する。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Source": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "User"
        }
    },
    "Findings": {
        "Original": {
            "Source": {
                "Prefetch": "実行履歴"
            }
        },
        "Additional": {
            "Source": {
                "監査ポリシー, Sysmon": "実行履歴"
            }
        }
    },
    "SuccessCondition": {
        "Source": [
            "「セキュリティ」ログのイベント4688で検体の実行が記録されており、イベント4689でプロセスの戻り値(実行結果)が、\"0x0\"となっている"
        ]
    },
    "KeyEvents": {
        "Source": {
            "EventLogs": [
                {
                    "Channel": "Security",
                    "EventID": 4688,
                    "Category": "Process Creation",
                    "Description": "新しいプロセスが作成されました。",
                    "SubjectUserSid": "[ユーザーSID]",
                    "SubjectUserName": "[ユーザー名]",
                    "SubjectDomainName": "[ドメイン名]",
                    "SubjectLogonId": "[ログオンID]",
                    "NewProcessId": "[新しく実行されたプロセスのプロセスID]",
                    "NewProcessName": "[実行ファイルのパス]",
