                    "CommandLine": "[実行ファイルのパス] [コマンドライン]",
                    "ProcessId": "[親プロセスID]",
                    "ParentProcessName": "[親プロセス名]"
                },
                {
                    "Channel": "Security",
                    "EventID": 4689,
                    "SubjectUserSid": "[ユーザーSID]",
                    "SubjectUserName": "[ユーザー名]",
                    "SubjectDomainName": "[ドメイン名]",
                    "SubjectLogonId": "[ログオンID]",
                    "Status": "0x0",
                    "ProcessId": "[実行プロセスID]",
                    "ProcessName": "[実行ファイルのパス]"
                }
            ],
            "Prefetch": [
                {
                    "File": "C:\\Windows\\Prefetch\\[実行ファイル名]-[文字列].pf",
                    "Process Name": "[実行ファイル名]",
                    "Process Path": "[実行ファイルのパス]"
