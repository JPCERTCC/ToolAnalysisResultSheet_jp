{
    "Summary": {
        "ToolName": "timestomp",
        "Category": "痕跡の削除",
        "Description": "ファイルのタイムスタンプを変更する。",
        "Usage": "攻撃者が利用したことでタイムスタンプが変更されたファイルのタイムスタンプを戻すことで、ファイルに対してアクセスしたことを隠蔽する。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
