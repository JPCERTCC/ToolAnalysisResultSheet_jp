    "Summary": {
        "ToolName": "BITS",
        "Category": "ファイル共有・転送",
        "Description": "バックグラウンドでファイルを送受信する。送受信の際、優先度などを設定することが可能。",
        "Usage": "他の通信と比較して目立たない程度の帯域で、ファイルを送受信する。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
