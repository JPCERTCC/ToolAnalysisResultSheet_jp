{
    "Summary": {
        "ToolName": "Htran",
        "Category": "通信の不正中継",
        "Description": "通信をトンネリングさせる。",
        "Usage": "ファイアウォールなどで許可されているポートを経由して、許可されていないポートの通信を通過させる。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Source": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "User",
            "Protocol": ["任意のTCPポート"]
        },
        "Target": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "User",
            "Protocol": ["任意のTCPポート"]
        }
    },
    "Findings": {
        "Original": {
            "Source": {
                "Prefetch": "実行履歴"
            },
            "Target": {
                "Prefetch": "実行履歴"
            }
        },
        "Additional": {
            "Source": {
                "監査ポリシー": "実行履歴、中継ホスト(攻撃者)・中継先ホスト(接続先)とのネットワーク通信"
            },
            "Target": {
                "監査ポリシー・Sysmon": "実行履歴、ネットワーク通信履歴"
            }
        }
    },
    "SuccessCondition": {
        "Source": [
            "「セキュリティ」ログのイベント5156において、中継ホスト・中継先ホストとそれぞれ通信している"
        ],
        "Target": [
            "「セキュリティ」ログのイベント5156において、想定していないホストからの通信が着信している"
        ]
    },
    "KeyEvents": {
        "Source": {
            "EventLogs": [
                {
                    "Channel": "Security",
                    "EventID": 4688,
                    "SubjectUserSid": "[実行ユーザーSID]",
                    "SubjectUserName": "[実行ユーザー名]",
                    "SubjectDomainName": "[ドメイン名]",
                    "SubjectLogonId": "[ログオンID]",
                    "NewProcessId": "[新しく実行されたプロセスのプロセスID]",
                    "NewProcessName": "[実行ファイルのパス]",
                    "CommandLine": "[実行ファイル名] -tran [中継ホストの待受ポート番号] [中継先IPアドレス] [中継先ポート番号]",
                    "ProcessId": "[親プロセスID]"
                },
                {
                    "Channel": "Security",
                    "EventID": 5156,
                    "ProcessId": "[実行プロセスID]",
                    "Application": "[実行ファイルのパス]",
                    "Direction": "着信",
                    "SourceAddress": "[接続元IPアドレス]",
                    "SourcePort": "[接続元ポート番号]",
                    "DestAddress": "[中継ホストIPアドレス]",
                    "DestPort": "[中継ホストの待受ポート番号]",
                    "Protocol": "6 (TCP)"
                },
                {
                    "Channel": "Security",
                    "EventID": 5156,
                    "ProcessId": "[実行プロセスID]",
                    "Application": "[実行ファイルのパス]",
                    "Direction": "送信",
                    "SourceAddress": "[中継ホストIPアドレス]",
                    "SourcePort": "[中継ホストの接続元ポート番号]",
                    "DestAddress": "[中継先IPアドレス]",
                    "DestPort": "[中継先ポート番号]",
                    "Protocol": "6 (TCP)"
                }
            ],
            "Prefetch": [
                {
                    "File": "[実行ファイル名]-[ハッシュ値].pf",
                    "Process Name": "[実行ファイル名]",
                    "Process Path": "\\VOLUME{[ボリュームGUID]}\\WINDOWS\\SYSTEM32\\[実行ファイル名]"
