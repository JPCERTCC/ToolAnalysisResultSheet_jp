                {
                    "File": "[実行ファイル名]-[ハッシュ値].pf",
                    "Operation": [
                        "DataExtend+FileCreate+Close"
                    ]
                }
            ]
        },
        "Target": {
            "EventLogs": [
                {
                    "Channel": "Security",
                    "EventID": 5156,
                    "ProcessId": "4",
                    "Application": "System",
                    "Direction": "着信",
