{
    "Summary": {
        "ToolName": "Mimikatz (Golden Ticket)",
        "Category": "管理者権限/アカウントの奪取",
        "Description": "不正にKerberosの認証チケットを作成し、リモートホストに接続する。",
        "Usage": "不正に作成した認証チケットを使用してリモートホストにログオンする。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Source": {
            "OS": "Windows",
            "DomainMember": true,
            "Privilege": "Admin",
            "Protocol": ["88/tcp", "445/tcp"]
        },
        "Target": {
            "OS": "Windows",
            "DomainMember": true,
            "Privilege": "Admin",
            "Protocol": ["88/tcp", "445/tcp"]
        }
    },
    "Findings": {
        "Original": {
            "Source": {
                "Prefetch": "実行履歴"
            }
        },
        "Additional": {
            "Source": {
                "監査ポリシー・Sysmon": "実行履歴、チケット作成ログ（/ticketオプションを利用した場合）"
            },
            "Target": {
                "監査ポリシー": "Kerberos認証を用いたログオン履歴"
            }
        }
    },
    "SuccessCondition": {
        "Source": [
            "チケット情報である.kirbi拡張子のファイルが作成されている"
        ],
        "Target": [
            "「セキュリティ」ログのイベント4624・4769に、接続ユーザー名でログオンやKerberos サービス チケット要求が記録される。しかしながら、通常の認証とGolden Ticket攻撃を区別することは困難。一方で、Golden Ticket攻撃ではTGT発行に対応するイベント4768が記録されないため、前後のログ発生状況などからGolden Ticket攻撃が用いられたことを判断できる可能性はある"
        ]
    },
