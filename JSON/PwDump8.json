                    "SourceThreadId": "[スレッドID]",
                    "SourceImage": "[実行ファイルのパス]",
                    "TargetProcessId": "[winlogon.exeのプロセスID]",
                    "TargetImage": "C:\\WINDOWS\\system32\\winlogon.exe",
                    "GrantedAccess": "0x101001"
                }
            ],
            "Prefetch": [
                {
                    "File": "C:\\Windows\\Prefetch\\[実行ファイル名]-[ハッシュ値].pf",
                    "Process Name": "[実行ファイル名]",
                    "Process Path": "\\VOLUME{[ボリュームGUID]}\\WINDOWS\\SYSTEM32\\[実行ファイル名]"
