{
    "Summary": {
        "ToolName": "PWDump8",
        "Category": "パスワード、ハッシュ入手",
        "Description": "ホスト内のパスワードハッシュ一覧を表示する。",
        "Usage": "取得したハッシュ情報を利用して、他のホストにログオンする。",
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "none",
            "Windows 10 + Windows Server 2012": "none",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Source": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "Admin"
        }
    },
    "Findings": {
        "Original": {
            "Source": {
                "Prefetch": "実行履歴"
            }
        },
        "Additional": {
            "Source": {
                "監査ポリシー・Sysmon": "実行履歴、レジストリアクセス"
            }
        }
    },
    "SuccessCondition": {
        "Source": [
            "イベントログや実行履歴などからツールが実行されたことは分かるが、その成否や取得された情報を正確に見ることは出来ない"
        ]
    },
    "KeyEvents": {
        "Source": {
            "EventLogs": [
                {
                    "Channel": "Security",
                    "EventID": 4688,
                    "SubjectUserSid": "[実行ユーザーSID]",
                    "SubjectUserName": "[実行ユーザー名]",
