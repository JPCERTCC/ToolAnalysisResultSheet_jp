            ],
            "MFT": [
                {
                    "Path": "C:\\Windows\\Prefetch\\[実行ファイル名]-[ハッシュ値].pf",
                    "Flag": "FILE",
                    "Note": "InUse"
                }
            ],
            "USNJournal": [
                {
                    "File": "[実行ファイル名]-[ハッシュ値].pf",
                    "Operation": [
                        "DataExtend+FileCreate+Close"
                    ]
                }
            ]
        }
    },
