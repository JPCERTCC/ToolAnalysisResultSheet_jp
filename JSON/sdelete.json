{
    "Summary": {
        "ToolName": "sdelete",
        "Category": "痕跡の削除",
        "Description": "ファイルを複数回上書きしてから削除する。",
        "Usage": "攻撃の過程で作成されたファイルを、復元できないように削除する。",
        "Availability": [
            "",""
        ],
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Source": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "User"
        }
    },
    "Findings": {
        "Original": {
            "Source": {
                "レジストリ": "sdeleteに利用における使用許諾契約書への同意"
            }
        },
        "Additional": {
            "Source": {
                "プロセス追跡の監査": "sdeleteの実行履歴。グループポリシーで有効化している場合、引数から削除したファイル名が分かる",
                "ファイルシステムの監査": "複数回のファイル名変更、上書き、削除",
                "USNジャーナル": "複数回のファイル名変更、上書き、削除",
                "Sysmon": "sdeleteの実行履歴。引数から削除したファイル名が分かる"
            }
        }
    },
    "SuccessCondition": {
        "Source": [
            "イベントログ「セキュリティ」のイベントID: 4656、4663でファイル名がAAA.AAAからZZZ.ZZZまで順番に変更されることが確認できる",
            "USNジャーナルより、削除対象ファイルのデータが上書きされた後にファイル名がAAA.AAAからZZZ.ZZZまで順番に変更され、その後データが削除されることが確認できる"
        ]
    },
