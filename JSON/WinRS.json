        "Description": "リモートホスト上でコマンドを実行する。",
        "Usage": "BITSなどによりツールを送り込み、WinRSを用いてツールをリモートから実行する。",
        "Availability": [
            "",""
        ],
        "TestedOn": {
            "Windows 7 + Windows Server 2012": "true",
            "Windows 10 + Windows Server 2012": "true",
            "Windows 11 + Windows Server 2025": "true"
        }
    },
    "ExecCondition": {
        "Source": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "Admin"
        },
        "Target": {
            "OS": "Windows",
            "DomainMember": false,
            "Privilege": "Admin",
            "Protocol": ["5985/tcp"],
            "Service": "Windows remote Management (WS-Management)",
